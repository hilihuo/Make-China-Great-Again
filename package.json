{
  "name": "china-road-museum",
  "productName": "中华人文史卷",
  "description": "以人物、事件、历史现场和三维展品重访中华人文史的沉浸式数字博物馆。",
  "author": {
    "name": "hilihuo",
    "email": "hslaiwork@gmail.com"
  },
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/vite-runner.mjs dev",
    "build": "node scripts/vite-runner.mjs build",
    "preview": "node scripts/vite-runner.mjs preview",
    "desktop:run": "npm run build && electron .",
    "desktop:exe": "npm run build && electron-builder --win nsis --x64",
    "android:sync": "npm run build && cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:release": "npm run android:sync && cd android && gradlew.bat assembleRelease"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "vite": "^5.2.11"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/core": "8.4.1",
    "three": "^0.165.0",
    "gsap": "^3.12.5"
  }
}
